rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== ヘルパー関数 ==========

    function isAuth() {
      return request.auth != null;
    }

    // 自分のユーザードキュメントが存在するか
    // ※ get(...).exists は存在しないプロパティ（常に undefined）で、これを使うと
    //   承認チェックが全端末で false になり events/venues/notifications/logs/eventData
    //   の読み取りが全滅する。存在確認は必ず exists() を使い、get() の前段でガードする。
    function userDocExists(teamId) {
      return exists(/databases/$(database)/documents/teams/$(teamId)/users/$(request.auth.uid));
    }

    function userData(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/users/$(request.auth.uid)).data;
    }

    function isApproved(teamId) {
      return userDocExists(teamId) && userData(teamId).status == 'approved';
    }

    function userRole(teamId) {
      return userDocExists(teamId) ? userData(teamId).role : 'none';
    }

    function isManager(teamId) {
      return isApproved(teamId) && userRole(teamId) in ['admin', 'coach', 'assist', 'officer'];
    }

    function isAdmin(teamId) {
      return isApproved(teamId) && userRole(teamId) == 'admin';
    }

    // ========== チームデータ ==========

    match /teams/{teamId} {

      // ----- 管理者設定（アプリからは読み取り専用・Firebase Consoleのみ変更可）-----
      // ※ このドキュメントは Firebase Console から手動で初期設定してください
      match /config/{configId} {
        allow read:  if isAuth() && isManager(teamId);
        allow write: if false;  // アプリからは変更不可。Firebase Console/Admin SDK のみ
      }

      // ----- ユーザープロファイル（保護者・スタッフ登録・承認管理）-----
      match /users/{uid} {
        // 自分のプロフィールは読める。マネージャーは全員分読める
        // 認証済みユーザーは承認済みユーザーの存在確認クエリが可能（初回管理者ブートストラップ用）
        allow read: if isAuth() && (request.auth.uid == uid || isManager(teamId) || resource.data.status == 'approved');

        // 新規登録申請: 自分の UID で、status='pending', role='parent' のみ作成可
        // ※ 初代管理者は Firebase Console から手動作成する（自己昇格の穴を塞ぐため
        //    「承認済み0人ならadmin自己作成可」のブートストラップ条項は撤廃済み）
        allow create: if isAuth()
          && request.auth.uid == uid
          && request.resource.data.status == 'pending'
          && request.resource.data.role == 'parent';

        // マネージャーは承認・役割変更が可能
        // ただし自分自身の status/role は変更不可（自分昇格防止）
        // admin 役割の付与・剥奪は admin のみ可能
        allow update: if isAuth()
          && isManager(teamId)
          && request.auth.uid != uid
          && (request.resource.data.role != 'admin' || isAdmin(teamId))
          && (resource.data.role != 'admin' || isAdmin(teamId));

        // 削除は不可（Firebase Console のみ）
        allow delete: if false;
      }

      // ----- メンバー（選手・スタッフ一覧）-----
      match /members/{memberId} {
        // 認証済みなら誰でも読める（新規登録時に子供選択のために必要）
        allow read: if isAuth();

        // 作成・更新: マネージャーのみ
        // TODO: 将来的にその選手の保護者も編集可にする
        allow create, update: if isAuth() && isManager(teamId);
        allow delete: if isAuth() && isManager(teamId);
      }

      // ----- イベント（予定）-----
      match /events/{eventId} {
        allow read: if isAuth() && isApproved(teamId);
        // 承認済みユーザーなら誰でも作成・編集・削除可（ユーザーの方針）
        allow write: if isAuth() && isApproved(teamId);
      }

      // ----- 会場 -----
      match /venues/{venueId} {
        allow read: if isAuth() && isApproved(teamId);
        allow write: if isAuth() && isManager(teamId);
      }

      // ----- 連絡事項 -----
      match /notifications/{notifId} {
        allow read:   if isAuth() && isApproved(teamId);
        allow write:  if isAuth() && isApproved(teamId);
      }

      // ----- ログ -----
      match /logs/{logId} {
        allow read:   if isAuth() && isManager(teamId);
        allow create: if isAuth() && isApproved(teamId);
        allow update, delete: if false;
      }

      // ----- イベント固有データ（配車・出欠・座席割り当て）-----
      match /eventData/{dataId} {
        allow read, write: if isAuth() && isApproved(teamId);
      }

      // ----- 当番表 設定（機能ON/OFF）-----
      match /dutySettings/{settingId} {
        allow read:  if isAuth() && isApproved(teamId);
        allow write: if isAuth() && isManager(teamId);
      }

      // ----- 当番グループ（当番の割り当て単位）-----
      match /dutyGroups/{groupId} {
        allow read:  if isAuth() && isApproved(teamId);
        allow write: if isAuth() && isManager(teamId);
      }

      // ----- 当番割り当て（イベント×グループ）-----
      // eventDataやeventsは承認済みなら誰でも書き込み可のため、当番割り当ては
      // マネージャー限定にするために別コレクションに分離している
      match /dutyAssignments/{eventId} {
        allow read:  if isAuth() && isApproved(teamId);
        allow write: if isAuth() && isManager(teamId);
      }
    }
  }
}
