rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 認証済みユーザーのみ読み書き可能
    match /teams/{teamId}/{allPaths=**} {
      allow read, delete: if request.auth != null;
      // 書き込みは1ファイル10MBまで（クライアント側チェックと二重の防御）
      allow write: if request.auth != null
        && request.resource.size <= 10 * 1024 * 1024;
    }
  }
}
